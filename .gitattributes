# Enforce LF in the working tree on every platform, so oxfmt (which wants LF) and
# diffs stay consistent regardless of a checkout's git autocrlf setting.
* text=auto eol=lf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.mp4  binary
*.woff  binary
*.woff2 binary
*.exe  binary
*.p12  binary
*.pfx  binary
