# Copy to .env and fill in. Bun auto-loads .env; .env is gitignored.
# Throwaway GameForge/Metin2 accounts only.

UNFORGE_EMAIL=
UNFORGE_PASSWORD=

# Optional overrides.
UNFORGE_LOCALE=en-GB
# Stable per account — generated + printed if omitted, then paste it back here.
UNFORGE_INSTALLATION_ID=
# Path to the launcher's PEM certificate; needed only for the thin/codes step.
UNFORGE_CERT_PEM=./cert.pem
